  <h2>Árbol AVL - ArbolAVL&lt;T&gt;</h2>
  <p class="ruta">Archivo: src/main/java/estructuras/avl/ArbolAVL.java</p>
  <table>
    <tr><th>Método (firma)</th><th>Descripción</th><th>Notas / Complejidad</th></tr>
    <tr><td>public ArbolAVL()</td><td>Constructor: raiz=null.</td><td>-</td></tr>
    <tr><td>private int altura(NodoAVL&lt;T&gt; nodo)</td><td>Devuelve la altura del nodo (0 si null).</td><td>Helper para balanceo.</td></tr>
    <tr><td>private int factorBalanceo(NodoAVL&lt;T&gt; nodo)</td><td>Calcula el factor de balanceo (altura(left)-altura(right)).</td><td>Helper.</td></tr>
    <tr><td>private void updateAltura(NodoAVL&lt;T&gt; nodo)</td><td>Actualiza el campo altura del nodo basado en hijos.</td><td>Helper.</td></tr>
    <tr><td>private NodoAVL&lt;T&gt; rotacionDerecha(NodoAVL&lt;T&gt; y)</td><td>Realiza rotación derecha y devuelve nueva raíz local.</td><td>Operación O(1).</td></tr>
    <tr><td>private NodoAVL&lt;T&gt; rotacionIzquierda(NodoAVL&lt;T&gt; x)</td><td>Rotación izquierda.</td><td>O(1).</td></tr>
    <tr><td>private NodoAVL&lt;T&gt; balanceo(NodoAVL&lt;T&gt; nodo)</td><td>Rebalancea nodo aplicando las rotaciones necesarias.</td><td>Usado tras inserción/borrado.</td></tr>
    <tr><td>public void insert(T dato)</td><td>Inserta dato en el árbol (O(log n) amortizado por balanceo).</td><td>Invoca método privado recursivo <code>insert(NodoAVL, T)</code>.</td></tr>
    <tr><td>private NodoAVL&lt;T&gt; insert(NodoAVL&lt;T&gt; nodo, T dato)</td><td>Inserción recursiva con balanceo al retornar.</td><td>Devuelve la nueva subraíz.</td></tr>
    <tr><td>public T search(T dato)</td><td>Busca y devuelve el dato si existe (o null).</td><td>Usa método privado recursivo.</td></tr>
    <tr><td>private NodoAVL&lt;T&gt; search(NodoAVL&lt;T&gt; nodo, T dato)</td><td>Búsqueda recursiva por comparación.</td><td>O(log n) si balanceado.</td></tr>
    <tr><td>public void delete(T dato)</td><td>Elimina el dato del árbol (usa método privado recursivo).</td><td>Realiza reestructuración y balanceo.</td></tr>
    <tr><td>private NodoAVL&lt;T&gt; delete(NodoAVL&lt;T&gt; nodo, T dato)</td><td>Implementa casos de borrado (0,1,2 hijos) y balanceo.</td><td>O(log n).</td></tr>
    <tr><td>private NodoAVL&lt;T&gt; minNodo(NodoAVL&lt;T&gt; nodo)</td><td>Devuelve el nodo con el mínimo valor en subárbol (izquierda más profunda).</td><td>Helper para delete.</td></tr>
    <tr><td>public ListaEnlazada&lt;T&gt; inOrden()</td><td>Devuelve una lista con recorrido in-order.</td><td>O(n).</td></tr>
    <tr><td>private void inOrder(NodoAVL&lt;T&gt; nodo, ListaEnlazada&lt;T&gt; lista)</td><td>Recorrido recursivo.</td><td>Helper.</td></tr>
    <tr><td>public NodoAVL&lt;T&gt; getRoot()</td><td>Devuelve la raíz del árbol.</td><td>Exposición de la estructura interna.</td></tr>
    <tr><td>public int getHeight()</td><td>Altura del árbol (altura de la raíz).</td><td>-</td></tr>
    <tr><td>public boolean isEmpty()</td><td>Indica si el árbol está vacío.</td><td>-</td></tr>
  </table>

