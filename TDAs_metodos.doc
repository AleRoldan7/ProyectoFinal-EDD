  <h2>Grafo - Grafo</h2>
  <p class="ruta">Archivo: src/main/java/estructuras/grafos/Grafo.java</p>
  <table>
    <tr><th>Método (firma)</th><th>Descripción</th><th>Notas</th></tr>
    <tr><td>public Grafo()</td><td>Constructor: inicializa arreglo de nodos y totalNodos=0.</td><td>-</td></tr>
    <tr><td>private int buscarIndice(int idSucursal)</td><td>Busca el índice interno del nodo con idSucursal.</td><td>O(n) lineal en totalNodos.</td></tr>
    <tr><td>public void agregarSucursal(int idSucursal)</td><td>Agrega un nuevo NodoGrafo si no existe ya.</td><td>Aumenta totalNodos.</td></tr>
    <tr><td>private boolean existeConexion(int origen, int destino)</td><td>Verifica si ya existe arista origen->destino.</td><td>Helper usado antes de insertar.</td></tr>
    <tr><td>public void agregarConexion(int origen, int destino, double tiempo, double costo)</td><td>Agrega arista dirigida con tiempo y costo.</td><td>Inserta al inicio de la lista de aristas del nodo origen.</td></tr>
    <tr><td>public void agregarConexionBiDireccional(int origen, int destino, double tiempo, double costo)</td><td>Agrega aristas en ambas direcciones.</td><td>-</td></tr>
    <tr><td>public ResultadoRuta determinaDijkstra(int origen, int destino, boolean usarTiempo)</td><td>Calcula ruta mínima usando Dijkstra; retorna ruta y costo/tiempo.</td><td>Usa ColaPrioridad; complejidad depende de estructura (aquí heap simple). Retorna ResultadoRuta con ruta o -1 si no hay ruta.</td></tr>
    <tr><td>public void cargarConexionesCSV(String archivo)</td><td>Lee CSV (formato origen,destino,tiempo,costo) y agrega conexiones.</td><td>Ignora líneas inválidas; imprime totalNodos al finalizar.</td></tr>
    <tr><td>public int getTotalNodos()</td><td>Devuelve número de nodos cargados.</td><td>-</td></tr>
    <tr><td>public NodoGrafo[] getNodos()</td><td>Devuelve arreglo interno de nodos.</td><td>Exposición interna.</td></tr>
    <tr><td>public int getIdSucursal(int idx)</td><td>Devuelve idSucursal del nodo en índice idx.</td><td>-</td></tr>
    <tr><td>public NodoArista getAristas(int idx)</td><td>Retorna la lista de aristas del nodo en índice idx.</td><td>-</td></tr>
    <tr><td>public NodoArista getAdyacentesPorId(int idSucursal)</td><td>Retorna listado de aristas para la sucursal dada (busca por id).</td><td>-</td></tr>
    <tr><td>public String obtenerConexionesComoTexto()</td><td>Devuelve un String con todas las conexiones (para mostrar).</td><td>Útil para UI/depuración.</td></tr>
  </table>

  <h2>NodoGrafo</h2>
  <p class="ruta">Archivo: src/main/java/estructuras/grafos/NodoGrafo.java</p>
  <table>
    <tr><th>Método / Campo</th><th>Descripción</th><th>Notas</th></tr>
    <tr><td>public NodoGrafo(int idSucursal)</td><td>Constructor que inicializa idSucursal y listaArista=null.</td><td>-</td></tr>
    <tr><td>getIdSucursal / setIdSucursal</td><td>Getter/Setter idSucursal.</td><td>-</td></tr>
    <tr><td>getListaArista / setListaArista</td><td>Getter/Setter de la lista de aristas (NodoArista).</td><td>-</td></tr>
  </table>

  <h2>NodoArista</h2>
  <p class="ruta">Archivo: src/main/java/estructuras/grafos/NodoArista.java</p>
  <table>
    <tr><th>Método / Campo</th><th>Descripción</th><th>Notas</th></tr>
    <tr><td>public NodoArista(int destino, double tiempo, double costo)</td><td>Constructor para crear una arista con datos.</td><td>-</td></tr>
    <tr><td>getDestino / setDestino</td><td>Getter/Setter destino (idSucursal destino).</td><td>-</td></tr>
    <tr><td>getTiempo / setTiempo</td><td>Getter/Setter tiempo.</td><td>-</td></tr>
    <tr><td>getCosto / setCosto</td><td>Getter/Setter costo.</td><td>-</td></tr>
    <tr><td>getSiguiente / setSiguiente</td><td>Getter/Setter para la siguiente arista en la lista.</td><td>-</td></tr>
  </table>

  <h2>Cola de prioridad - ColaPrioridad</h2>
  <p class="ruta">Archivo: src/main/java/estructuras/grafos/ColaPrioridad.java</p>
  <table>
    <tr><th>Método (firma)</th><th>Descripción</th><th>Notas</th></tr>
    <tr><td>public ColaPrioridad(int capacidad)</td><td>Constructor que inicializa heap con capacidad dada.</td><td>-</td></tr>
    <tr><td>private int padre(int i), hijoIzq(int i), hijoDer(int i)</td><td>Índices auxiliares para heap.</td><td>Helpers privados.</td></tr>
    <tr><td>private void intercambiar(int i, int j)</td><td>Intercambia entradas en el heap.</td><td>Helper.</td></tr>
    <tr><td>public void insertar(int nodo, double distancia)</td><td>Inserta una entrada (nodo, distancia) y mantiene heap mínimo.</td><td>Lanza RuntimeException si heap lleno.</td></tr>
    <tr><td>public Entrada extraerMinimo()</td><td>Extrae y retorna la entrada con menor distancia (min-heap).</td><td>Rearma heap con heapifyDown.</td></tr>
    <tr><td>private void heapifyDown(int i)</td><td>Desciende elemento para mantener heap mínimo.</td><td>Helper.</td></tr>
    <tr><td>public boolean isEmpty()</td><td>Indica si el heap está vacío.</td><td>-</td></tr>
    <tr><td>public int size()</td><td>Numero de entradas en el heap.</td><td>-</td></tr>
  </table>

  <hr>
  <p class="nota">Notas finales: Si deseas que incluya ejemplos de uso (pequeños fragmentos de código) para cada TDA, o que haga el documento en formato .docx, lo puedo añadir. También puedo exportar estas tablas a un archivo Markdown o CSV si lo prefieres.</p>
