    <tr><td>public Nodo(T producto)</td><td>Constructor: inicializa el nodo con producto y next=null.</td><td>-</td></tr>
    <tr><td>public T getProducto()</td><td>Getter del producto.</td><td>-</td></tr>
    <tr><td>public void setProducto(T producto)</td><td>Setter del producto.</td><td>-</td></tr>
    <tr><td>public Nodo&lt;T&gt; getNext()</td><td>Getter del siguiente nodo.</td><td>-</td></tr>
    <tr><td>public void setNext(Nodo&lt;T&gt; next)</td><td>Setter del siguiente nodo.</td><td>-</td></tr>
    <tr><td>public T producto (campo)</td><td>Dato almacenado (acceso package/public en código actual).</td><td>Campo público; considera encapsular si quieres privacidad.</td></tr>
    <tr><td>public Nodo&lt;T&gt; next (campo)</td><td>Referencia al siguiente nodo.</td><td>Campo público; igual consideración de encapsulación.</td></tr>
  </table>

