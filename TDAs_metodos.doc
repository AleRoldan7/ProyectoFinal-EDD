    <tr><td>private void insertarNoLleno(NodoB nodo, T clave)</td><td>Inserción en nodo no lleno (recursiva).</td><td>Helper.</td></tr>
    <tr><td>private void dividirHijo(NodoB&lt;T&gt; padre, int i)</td><td>Divide el hijo lleno en dos y ajusta claves/hijos del padre.</td><td>Helper para insertar.</td></tr>
    <tr><td>public boolean buscar(T clave)</td><td>Busca la clave en el árbol y retorna true si existe.</td><td>Usa método privado recursivo.</td></tr>
    <tr><td>private boolean buscar(NodoB&lt;T&gt; nodo, T clave)</td><td>Búsqueda recursiva.</td><td>-</td></tr>
    <tr><td>public ListaEnlazada&lt;T&gt; buscarRango(T desde, T hasta)</td><td>Retorna lista con claves en rango [desde, hasta].</td><td>Usa recorrido recursivo.</td></tr>
    <tr><td>public void eliminar(T clave)</td><td>Elimina clave del árbol y ajusta la estructura (préstamo/fusión).</td><td>Implementación completa con varios helpers privados.</td></tr>
    <tr><td>private void eliminar(NodoB nodo, T clave)</td><td>Recursivo para eliminar en nodo (manejando casos).</td><td>-</td></tr>
    <tr><td>private int encontrarIndice(NodoB nodo, T clave)</td><td>Obtiene índice donde debería estar la clave.</td><td>Helper.</td></tr>
    <tr><td>private void eliminarDeInterno(NodoB nodo, int idx)</td><td>Elimina desde un nodo interno (usa predecesor/sucesor o fusiona).</td><td>-</td></tr>
    <tr><td>private T obtenerPredecesor(NodoB nodo, int idx)</td><td>Devuelve predecesor para reemplazo en eliminación.</td><td>-</td></tr>
    <tr><td>private T obtenerSucesor(NodoB nodo, int idx)</td><td>Devuelve sucesor para reemplazo en eliminación.</td><td>-</td></tr>
    <tr><td>private void fusionar(NodoB nodo, int idx)</td><td>Fusiona hijo y su hermano, ajustando claves del padre.</td><td>-</td></tr>
    <tr><td>private void rellenar(NodoB nodo, int idx)</td><td>Garantiza que un hijo tenga suficientes claves antes de recursar.</td><td>Usa tomarDelAnterior / tomarDelSiguiente.</td></tr>
    <tr><td>private void tomarDelAnterior(NodoB nodo, int idx)</td><td>Toma una clave del hermano izquierdo (préstamo).</td><td>-</td></tr>
    <tr><td>private void tomarDelSiguiente(NodoB nodo, int idx)</td><td>Toma una clave del hermano derecho (préstamo).</td><td>-</td></tr>
    <tr><td>public boolean isEmpty()</td><td>Indica si el árbol está vacío.</td><td>-</td></tr>
    <tr><td>public NodoB getRaiz()</td><td>Retorna la raíz.</td><td>Permite inspección externa (UI/visualización).</td></tr>
  </table>

  <h2>Árbol B+ - ArbolBPlus&lt;T&gt;</h2>
  <p class="ruta">Archivo: src/main/java/estructuras/arbolBPlus/ArbolBPlus.java</p>
  <table>
    <tr><th>Método (firma)</th><th>Descripción</th><th>Notas</th></tr>
    <tr><td>public ArbolBPlus(int orden)</td><td>Constructor: inicializa orden y raíz hoja.</td><td>-</td></tr>
    <tr><td>public void insertar(T clave)</td><td>Inserta clave, dividiendo nodos cuando es necesario.</td><td>Implementación B+ con claves en hojas enlazadas.</td></tr>
    <tr><td>private void insertarNoLleno(NodoBPlus&lt;T&gt; nodo, T clave)</td><td>Inserción en nodo no lleno (recursiva).</td><td>-</td></tr>
    <tr><td>private void dividir(NodoBPlus&lt;T&gt; padre, int idx)</td><td>Divide un hijo y mueve claves/hijos al padre; en hojas enlaza siguiente.</td><td>En hojas, la clave media se conserva en hojas (comportamiento B+).</td></tr>
    <tr><td>private void insertarEnPadre(NodoBPlus padre, int idx, T clave, NodoBPlus nuevo)</td><td>Inserta referencia y clave en el padre tras división.</td><td>Helper.</td></tr>
    <tr><td>public boolean buscar(T clave)</td><td>Busca clave en hojas; devuelve true si existe.</td><td>Usa encontrarHoja.</td></tr>
    <tr><td>private NodoBPlus encontrarHoja(T clave)</td><td>Recorre árbol hasta la hoja correspondiente.</td><td>-</td></tr>
    <tr><td>public ListaEnlazada&lt;T&gt; buscarPorCategoria(T categoria)</td><td>Recorre hojas desde la hoja inicial recolectando claves que igualen la categoría.</td><td>Útil cuando las claves representan categorías.</td></tr>
    <tr><td>public ListaEnlazada&lt;T&gt; buscarRango(T desde, T hasta)</td><td>Retorna claves dentro del rango usando el enlace de hojas.</td><td>Eficiente para rangos (característica B+).</td></tr>
    <tr><td>public void eliminar(T clave)</td><td>Elimina clave y rebalancea si es necesario (merge/borrow).</td><td>Implementación con helpers; mantiene enlaces de hojas.</td></tr>
    <tr><td>private void eliminarRec(NodoBPlus&lt;T&gt; nodo, T clave)</td><td>Recursivo para eliminación y rebalanceo.</td><td>-</td></tr>
    <tr><td>private void eliminarEnHoja(NodoBPlus&lt;T&gt; nodo, T clave)</td><td>Elimina clave en la hoja si existe.</td><td>-</td></tr>
    <tr><td>private void rebalancear(NodoBPlus&lt;T&gt; padre, int idx)</td><td>Intenta tomar de hermanos o hacer merge si hijo queda con pocas claves.</td><td>-</td></tr>
    <tr><td>private void prestarDeIzquierda(...)</td><td>Préstamo desde hermano izquierdo.</td><td>-</td></tr>
    <tr><td>private void prestarDeDerecha(...)</td><td>Préstamo desde hermano derecho.</td><td>-</td></tr>
    <tr><td>private void merge(NodoBPlus&lt;T&gt; padre, int idx)</td><td>Fusiona hijo con su hermano derecho y actualiza padre.</td><td>-</td></tr>
    <tr><td>public ListaEnlazada&lt;T&gt; recorrerHojas()</td><td>Devuelve una lista con todas las claves recorriendo las hojas enlazadas.</td><td>O(n) en número de claves.</td></tr>
    <tr><td>public boolean isEmpty()</td><td>Indica si el árbol está vacío.</td><td>-</td></tr>
    <tr><td>public NodoBPlus&lt;T&gt; getRaiz()</td><td>Retorna la raíz.</td><td>-</td></tr>
  </table>

